programa {
    funcao inicio() {
        inteiro i, num, pos = 0, neg = 0, zero = 0

        para (i = 1; i <= 20; i++) {
            leia(num)
            se (num > 0) { pos++ }
            senao se (num < 0) { neg++ }
            senao { zero++ }
        }

        escreva(pos, "\n", neg, "\n", zero)
    }
}
