programa {
    funcao inicio() {
        inteiro i, idade, maiorIdade = 0, contEspecifico = 0
        caracter sexo, corOlhos, corCabelos

        para (i = 1; i <= 500; i++) {
            leia(sexo)
            leia(corOlhos)
            leia(corCabelos)
            leia(idade)

            se (idade > maiorIdade) {
                maiorIdade = idade
            }

            se (sexo == 'F' e idade >= 18 e idade <= 35 e corOlhos == 'V' e corCabelos == 'L') {
                contEspecifico++
            }
        }

        escreva(maiorIdade, "\n")
        escreva(contEspecifico)
    }
}
